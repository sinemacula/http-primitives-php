{
    "name": "sinemacula/http-primitives-php",
    "type": "library",
    "description": "Standalone, framework-agnostic PHP 8.3+ package providing typed backed enums for HTTP protocol primitives with zero runtime dependencies.",
    "keywords": [
        "sine macula",
        "http",
        "enums",
        "status codes",
        "php"
    ],
    "license": "Apache-2.0",
    "authors": [
        {
            "name": "Ben Carey",
            "email": "bdmc@sinemacula.co.uk"
        }
    ],
    "require": {
        "php": "^8.3"
    },
    "require-dev": {
        "brianium/paratest": "^7.20",
        "friendsofphp/php-cs-fixer": "^3.94",
        "infection/infection": "^0.33.2",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpdoc-parser": "^2.3",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^12.5",
        "sinemacula/coding-standards": "^1.19.0",
        "slevomat/coding-standard": "^8.28",
        "squizlabs/php_codesniffer": "^4.0",
        "symfony/http-foundation": "^7.0|^8.0"
    },
    "autoload": {
        "psr-4": {
            "SineMacula\\Http\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "check": [
            "qlty check"
        ],
        "format": [
            "qlty fmt"
        ],
        "smells": [
            "qlty smells"
        ],
        "test": [
            "@php vendor/bin/paratest"
        ],
        "test:coverage": [
            "@php vendor/bin/paratest --coverage-clover=clover.xml"
        ],
        "test:mutation": [
            "@php vendor/bin/infection --configuration=infection.json5 --test-framework-options=\"--do-not-fail-on-warning --do-not-fail-on-phpunit-warning\" --only-covering-test-cases --threads=max --git-diff-lines --git-diff-base=origin/master --map-source-class-to-test --min-msi=90 --min-covered-msi=90 --ignore-msi-with-no-mutations"
        ],
        "test:mutation:full": [
            "@php vendor/bin/infection --configuration=infection.full.json5 --test-framework-options=\"--do-not-fail-on-warning --do-not-fail-on-phpunit-warning\" --only-covering-test-cases --threads=max"
        ]
    },
    "scripts-descriptions": {
        "check": "Run static analysis and lint checks via qlty.",
        "format": "Format codebase using qlty.",
        "smells": "Report code smells (duplication, complexity) via qlty.",
        "test": "Run the PHPUnit test suite in parallel using Paratest.",
        "test:coverage": "Run the PHPUnit test suite with clover coverage report.",
        "test:mutation": "Run the Infection mutation-testing gate against the MSI thresholds.",
        "test:mutation:full": "Run the full Infection mutation suite without MSI thresholds."
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "infection/extension-installer": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
