{
    $schema: "./vendor/infection/infection/resources/schema.json",
    source: {
        directories: [
            "src"
        ]
    },
    logs: {
        summary: "build/infection-summary.log",
        text: "build/infection.log"
    },
    phpUnit: {
        configDir: ".",
        customPath: "vendor/bin/phpunit"
    },
    timeout: 15,
    mutators: {
        "@default": true
    }
}
